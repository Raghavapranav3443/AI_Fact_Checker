# ─── SERVER CONFIGURATION ──────────────────────────────────────────────
# Port the backend will run on (default: 8000)
PORT=8000

# Host to bind the server to (default: 0.0.0.0)
HOST=0.0.0.0

# CORS Allowed Origins (comma-separated list)
# Example: http://localhost:5173,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ─── API KEYS (MANDATORY) ──────────────────────────────────────────────
# Groq Cloud API Key (for LLM reasoning)
# Get it here: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Tavily API Key (for web search and evidence retrieval)
# Get it here: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# ─── API KEYS (OPTIONAL) ───────────────────────────────────────────────
# Hive Moderation API Key (for image AI/Deepfake detection)
# Get it here: https://dashboard.thehive.ai/
# If left as default or empty, media detection will be gracefully skipped.
HIVE_API_KEY=your_hive_api_key_here

# ─── SYSTEM FLAGS ──────────────────────────────────────────────────────
# Demo Cache Mode (true/false)
# If true, the system will serve pre-cached reports for specific demo inputs
# without consuming API credits.
DEMO_CACHE_MODE=false
